# =============================================================
# hydrotrack_notebook — Environment Variables Template
# Only USGS M2M credentials are needed for v1.0 (Landsat).
# Future releases will add Copernicus for Sentinel-2/1.
# =============================================================

# USGS M2M API — required to download Landsat scenes
# Register free at: https://ers.cr.usgs.gov/register
# Both naming conventions are accepted by the notebook:
M2M_USERNAME=your_usgs_username   # or USGS_USERNAME
M2M_PASSWORD=your_usgs_password   # or USGS_PASSWORD

# HuggingFace — required for SAM3 Tracker inference
# Free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# -------------------------------------------------------------
# v2.0 — Sentinel-2 (Copernicus, coming soon)
# -------------------------------------------------------------
# COPERNICUS_USERNAME=your_copernicus_email
# COPERNICUS_PASSWORD=your_copernicus_password

# -------------------------------------------------------------
# v3.0 — Sentinel-1 SAR (ASF, coming soon)
# -------------------------------------------------------------
# ASF_USERNAME=your_asf_username
# ASF_PASSWORD=your_asf_password